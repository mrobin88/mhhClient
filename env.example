DATABASE_NAME=your_database_name
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_database_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Security toggles (safe defaults keep current behavior)
ENABLE_BASIC_AUTH=true
REQUIRE_STRONG_SECRET_KEY=false

# Public endpoint throttling
THROTTLE_PUBLIC_CLIENT_CREATE=20/hour
THROTTLE_KIOSK_LOOKUP=120/hour
THROTTLE_KIOSK_SUBMIT=40/hour
THROTTLE_KIOSK_UPLOAD=30/hour

# Pit Stop application alert recipients (comma-separated)
PITSTOP_APPLICATION_ALERT_EMAILS=ed@missionhiringhall.org,manager@missionhiringhall.org
